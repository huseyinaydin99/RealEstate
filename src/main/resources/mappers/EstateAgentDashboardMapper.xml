<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tr.com.huseyinaydin.repository.EstateAgentDashboardRepository">
    <select id="get5CityForChart" resultType="tr.com.huseyinaydin.dto.chart.ResultChartDto">
        Select City, Count(*) as CityCount From Product Group By City order By CityCount Desc Limit 5
    </select>
    
    <select id="productCountByEmployeeId" parameterType="int" resultType="int">
        Select Count(*) From Product Where AppUserId=#{id}
    </select>
    
    <select id="productCountByStatusTrue" parameterType="int" resultType="int">
        Select Count(*) From Product Where AppUserId=#{id} And ProductStatus=1
    </select>
    
    <select id="productCountByStatusFalse" parameterType="int" resultType="int">
        Select Count(*) From Product Where AppUserId=#{id} And ProductStatus=0
    </select>
    
    <select id="allProductCount" resultType="int">
        Select Count(*) From Product
    </select>
</mapper>
