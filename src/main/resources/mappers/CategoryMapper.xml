<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tr.com.huseyinaydin.repository.CategoryRepository">
    <select id="getAllCategory" resultType="tr.com.huseyinaydin.dto.category.ResultCategoryDto">
        Select * From Category
    </select>

    <insert id="createCategory" parameterType="tr.com.huseyinaydin.dto.category.CreateCategoryDto">
        insert into Category (CategoryName, CategoryStatus) values (#{categoryName}, #{categoryStatus})
    </insert>

    <delete id="deleteCategory" parameterType="int">
        Delete From Category Where CategoryID=#{categoryId}
    </delete>

    <update id="updateCategory" parameterType="tr.com.huseyinaydin.dto.category.UpdateCategoryDto">
        Update Category Set CategoryName=#{categoryName}, CategoryStatus=#{categoryStatus} where CategoryID=#{categoryID}
    </update>

    <select id="getCategory" parameterType="int" resultType="tr.com.huseyinaydin.dto.category.ResultCategoryDto">
        Select * From Category Where CategoryID=#{categoryId}
    </select>
</mapper>
