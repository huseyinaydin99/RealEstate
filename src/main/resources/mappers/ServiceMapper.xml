<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tr.com.huseyinaydin.repository.ServiceRepository">
    <select id="getAllService" resultType="tr.com.huseyinaydin.dto.service.ResultServiceDto">
        Select * From Service
    </select>

    <insert id="createService" parameterType="tr.com.huseyinaydin.dto.service.CreateServiceDto">
        insert into Service (ServiceName, ServiceStatus) values (#{serviceName}, #{serviceStatus})
    </insert>

    <delete id="deleteService" parameterType="int">
        Delete From Service Where ServiceID=#{id}
    </delete>
</mapper>
