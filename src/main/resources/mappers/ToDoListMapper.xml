<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tr.com.huseyinaydin.repository.ToDoListRepository">
    <select id="getAllToDoList" resultType="tr.com.huseyinaydin.dto.todolist.ResultToDoListDto">
        Select * From ToDoList
    </select>
    <insert id="createToDoList" parameterType="string">
        insert into ToDoList (Description, ToDoListStatus) values (#{description}, 0)
    </insert>
    <delete id="deleteToDoList" parameterType="int">
        Delete From ToDoList where ToDoListID=#{id}
    </delete>
    <update id="toDoListStatusChangeToTrue" parameterType="int">
        Update ToDoList Set ToDoListStatus=1 where ToDoListID=#{id}
    </update>
    <update id="toDoListStatusChangeToFalse" parameterType="int">
        Update ToDoList Set ToDoListStatus=0 where ToDoListID=#{id}
    </update>
</mapper>
